// =============================================================================
// fft1024_mag.v
// FFT 1024 pontos, Radix-2 DIT, implementação sequencial.
// Compatível com Quartus II 12.1 / Verilog-2001.
// Todas as variáveis declaradas no escopo do módulo (sem reg local em begin).
//
// Twiddle factors Q15 embutidos na tabela initial.
// Fs=48kHz, N=1024 → resolução=46.875 Hz/bin
// =============================================================================
module fft1024_mag (
    input  wire        clk,
    input  wire        rst,
    input  wire        start,
    output reg  [9:0]  rd_addr,
    input  wire signed [15:0] rd_data,
    output reg  [9:0]  peak_bin,
    output reg         done
);

// ---------------------------------------------------------------------------
// Twiddle factor ROMs (512 × 16 bits, Q15)
// ---------------------------------------------------------------------------
reg signed [15:0] twiddle_cos [0:511];
reg signed [15:0] twiddle_sin [0:511];

initial begin
