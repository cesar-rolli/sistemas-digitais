// =============================================================================
// i2s_receiver.v
// Recebe o sinal I2S do WM8731 (modo master, 16 bits, alinhamento I2S padrão).
// Captura o canal esquerdo (LRCLK = 0) e gera pulso sample_valid no clk do sistema.
//
// Protocolo I2S padrão:
//   - LRCLK = 0  → canal esquerdo (Left)
//   - LRCLK = 1  → canal direito (Right)
//   - Dados chegam MSB primeiro, um ciclo de BCLK após a transição de LRCLK
//   - 16 bits válidos seguidos de bits "don't care" se MCLK/BCLK > 32×Fs
// =============================================================================
module i2s_receiver (
    input  wire        bclk,         // bit clock do WM8731 (≈3.072 MHz para 48 kHz)
    input  wire        lrclk,        // LR clock (48 kHz)
    input  wire        adc_dat,      // dado serial
    input  wire        sys_clk,      // clock do sistema (50 MHz) para saída síncrona
    input  wire        rst,
    output reg  signed [15:0] sample_out,
    output reg         sample_valid
);

// ---------------------------------------------------------------------------
// Sincronização de BCLK e LRCLK para o domínio do sys_clk
// ---------------------------------------------------------------------------
reg [2:0] bclk_sync, lrclk_sync, adc_sync;
always @(posedge sys_clk or posedge rst) begin
    if (rst) begin
        bclk_sync  <= 3'b0;
        lrclk_sync <= 3'b0;
        adc_sync   <= 3'b0;
    end else begin
        bclk_sync  <= {bclk_sync[1:0],  bclk};
        lrclk_sync <= {lrclk_sync[1:0], lrclk};
        adc_sync   <= {adc_sync[1:0],   adc_dat};
    end
end

// Bordas detectadas no domínio sys_clk
wire bclk_fall  = (bclk_sync[2:1]  == 2'b10);
wire lrclk_fall = (lrclk_sync[2:1] == 2'b10);  // L→H: transição L→D para canal esquerdo
wire lrclk_rise = (lrclk_sync[2:1] == 2'b01);
wire adc_bit    = adc_sync[1];

// ---------------------------------------------------------------------------
// Desserializador
// ---------------------------------------------------------------------------
reg [4:0] bit_cnt;     // contador de bits recebidos (0..15)
reg [15:0] shift;      // registrador de deslocamento
reg        capturing;  // 1 quando estamos capturando canal esquerdo

always @(posedge sys_clk or posedge rst) begin
    if (rst) begin
        bit_cnt      <= 5'd0;
        shift        <= 16'd0;
        capturing    <= 1'b0;
        sample_out   <= 16'd0;
        sample_valid <= 1'b0;
    end else begin
        sample_valid <= 1'b0;

        // LRCLK falling edge: início do canal esquerdo (protocolo I2S)
        // O primeiro bit chega 1 BCLK depois da queda do LRCLK
        if (lrclk_fall) begin
            capturing <= 1'b1;
            bit_cnt   <= 5'd0;
        end

        // LRCLK rising edge: início do canal direito — paramos de capturar
        if (lrclk_rise) begin
            capturing <= 1'b0;
        end

        // Amostramos na borda de descida do BCLK (dado estável)
        if (bclk_fall && capturing) begin
            if (bit_cnt < 5'd16) begin
                shift   <= {shift[14:0], adc_bit};
                bit_cnt <= bit_cnt + 5'd1;
            end
            // Ao completar 16 bits, publica amostra
            if (bit_cnt == 5'd15) begin
                sample_out   <= {shift[14:0], adc_bit};
                sample_valid <= 1'b1;
            end
        end
    end
end

endmodule
