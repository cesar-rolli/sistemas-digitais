// =============================================================================
// fft.v  —  Top-level: DE2 Audio Spectrum Analyzer
// Placa  : Altera DE2 (Cyclone II EP2C35F672C6)
// Fs     : 48 kHz  |  FFT: 1024 pts  |  Resolução: ~46.9 Hz/bin
// Entrada: Line-In (WM8731)  |  Saída: LCD HD44780 16x2
// =============================================================================
module fft (
    input  wire        CLOCK_50,
    input  wire [3:0]  KEY,          // KEY[0] = reset ativo-baixo

    // WM8731
    input  wire        AUD_ADCDAT,
    input  wire        AUD_ADCLRCK,
    input  wire        AUD_BCLK,
    output wire        AUD_DACDAT,
    output wire        AUD_DACLRCK,
    output wire        AUD_XCK,

    // I2C
    output wire        I2C_SCLK,
    inout  wire        I2C_SDAT,

    // LCD HD44780 — modo 4 bits (nibble alto)
    output wire [7:4]  LCD_DATA,
    output wire        LCD_RS,
    output wire        LCD_RW,
    output wire        LCD_EN,
    output wire        LCD_ON,
    output wire        LCD_BLON,

    // LEDs de status
    output wire [7:0]  LEDR
);

// ---------------------------------------------------------------------------
// Reset e MCLK (12.5 MHz = 50 MHz / 4)
// ---------------------------------------------------------------------------
wire rst = ~KEY[0];

reg [1:0] mclk_div;
always @(posedge CLOCK_50 or posedge rst)
    if (rst) mclk_div <= 2'b00;
    else     mclk_div <= mclk_div + 2'b01;

assign AUD_XCK     = mclk_div[1];   // 12.5 MHz para o codec
assign AUD_DACDAT  = 1'b0;
assign AUD_DACLRCK = AUD_ADCLRCK;
assign LCD_ON      = 1'b1;
assign LCD_BLON    = 1'b1;

// ---------------------------------------------------------------------------
// 1. Configuração I2C do WM8731
// ---------------------------------------------------------------------------
wire i2c_done;

wm8731_i2c_config u_i2c (
    .clk  (CLOCK_50),
    .rst  (rst),
    .scl  (I2C_SCLK),
    .sda  (I2C_SDAT),
    .done (i2c_done)
);

// ---------------------------------------------------------------------------
// 2. Receptor I2S → amostra PCM 16 bits canal esquerdo
// ---------------------------------------------------------------------------
wire signed [15:0] sample_data;
wire               sample_valid;

i2s_receiver u_i2s (
    .bclk        (AUD_BCLK),
    .lrclk       (AUD_ADCLRCK),
    .adc_dat     (AUD_ADCDAT),
    .sys_clk     (CLOCK_50),
    .rst         (rst),
    .sample_out  (sample_data),
    .sample_valid(sample_valid)
);

// ---------------------------------------------------------------------------
// 3. Buffer de 1024 amostras + disparo da FFT
// ---------------------------------------------------------------------------
reg signed [15:0] sample_buf [0:1023];
reg [9:0]  wr_ptr;
reg        buf_rdy;
reg        fft_start;

always @(posedge CLOCK_50 or posedge rst) begin
    if (rst) begin
        wr_ptr    <= 10'd0;
        buf_rdy   <= 1'b0;
        fft_start <= 1'b0;
    end else begin
        fft_start <= 1'b0;
        if (sample_valid && i2c_done) begin
            sample_buf[wr_ptr] <= sample_data;
            if (wr_ptr == 10'd1023) begin
                wr_ptr    <= 10'd0;
                buf_rdy   <= 1'b1;
                fft_start <= 1'b1;
            end else
                wr_ptr <= wr_ptr + 10'd1;
        end
    end
end

// ---------------------------------------------------------------------------
// 4. FFT 1024 pontos
// ---------------------------------------------------------------------------
wire [9:0]         fft_rd_addr;
wire signed [15:0] fft_rd_data = sample_buf[fft_rd_addr];
wire [9:0]         fft_peak_bin;
wire               fft_done;

fft1024_mag u_fft (
    .clk      (CLOCK_50),
    .rst      (rst),
    .start    (fft_start),
    .rd_addr  (fft_rd_addr),
    .rd_data  (fft_rd_data),
    .peak_bin (fft_peak_bin),
    .done     (fft_done)
);

// ---------------------------------------------------------------------------
// 5. Frequência: freq_Hz = peak_bin × 375 / 8  (= peak_bin × 48000/1024)
// ---------------------------------------------------------------------------
reg [23:0] peak_freq_hz;

always @(posedge CLOCK_50 or posedge rst) begin
    if (rst)
        peak_freq_hz <= 24'd0;
    else if (fft_done)
        peak_freq_hz <= ({14'b0, fft_peak_bin} * 24'd375) >> 3;
end

// ---------------------------------------------------------------------------
// 6. LCD
// ---------------------------------------------------------------------------
wire [127:0] lcd_line1;
wire [127:0] lcd_line2;

freq_to_lcd u_fmt (
    .clk      (CLOCK_50),
    .rst      (rst),
    .freq_hz  (peak_freq_hz),
    .buf_rdy  (buf_rdy),
    .fft_done (fft_done),
    .line1    (lcd_line1),
    .line2    (lcd_line2)
);

lcd_controller u_lcd (
    .clk      (CLOCK_50),
    .rst      (rst),
    .line1    (lcd_line1),
    .line2    (lcd_line2),
    .lcd_rs   (LCD_RS),
    .lcd_rw   (LCD_RW),
    .lcd_en   (LCD_EN),
    .lcd_data (LCD_DATA)
);

// ---------------------------------------------------------------------------
// LEDs: [0]=I2C ok  [1]=buffer pronto  [2]=FFT done
// ---------------------------------------------------------------------------
assign LEDR = {5'b0, fft_done, buf_rdy, i2c_done};

endmodule
